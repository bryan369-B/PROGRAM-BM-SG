-- ============================================================

import Mathlib.Analysis.InnerProductSpace.Basic
import Mathlib.Topology.Algebra.Module.Basic
import Mathlib.Data.Real.Basic

variable {H : Type*}
  [SeminormedAddCommGroup H]
  [InnerProductSpace ℝ H]
  [CompleteSpace H]

variable {SB : Type*}
  [SeminormedAddCommGroup SB]
  [NormedSpace ℝ SB]

variable (ι : SB →L[ℝ] H)
variable (H_M : SB →L[ℝ] SB)
variable (log_Delta : SB →L[ℝ] SB)

def P3_C_signed : Prop :=
  ∀ v : SB, H_M v = -(log_Delta v)

-- Proyectores de Tomita-Takesaki
variable (P_pure P_err : H →L[ℝ] H)

axiom TT_decomp : ∀ v : H, P_pure v + P_err v = v
axiom TT_orth : ∀ v w : H, @inner ℝ H _ (P_pure v) (P_err w) = 0
axiom TT_idem_pure : ∀ v : H, P_pure (P_pure v) = P_pure v
axiom TT_idem_err  : ∀ v : H, P_err (P_err v) = P_err v

variable (T_hecke : ℕ → SB →L[ℝ] SB)

axiom hecke_commutes_HM :
  ∀ (n : ℕ) (v : SB), H_M (T_hecke n v) = T_hecke n (H_M v)

variable (μ_hecke : ℕ → SB →L[ℝ] SB)

-- ──────────────────────────────────────────────────────────────
-- AXIOMA A1: [H_M, μ_p] v = -log(p) · μ_p v
-- Justificación: BC1995 + convención BM-SG
-- ──────────────────────────────────────────────────────────────
axiom A1_HM_commutator (p : ℕ) (hp : 1 < p) (v : SB) :
    H_M (μ_hecke p v) - μ_hecke p (H_M v) =
      (-(Real.log p)) • (μ_hecke p v)

-- ──────────────────────────────────────────────────────────────
-- AXIOMA A2: [log∆, μ_p] v = +log(p) · μ_p v
-- Justificación: Flujo modular BC1995 Th.6.3
-- ──────────────────────────────────────────────────────────────
axiom A2_logDelta_commutator (p : ℕ) (hp : 1 < p) (v : SB) :
    log_Delta (μ_hecke p v) - μ_hecke p (log_Delta v) =
      (Real.log p) • (μ_hecke p v)

-- ──────────────────────────────────────────────────────────────
-- LEMA CENTRAL: [H_M + log∆, μ_p] = 0
-- ──────────────────────────────────────────────────────────────
lemma commutator_sum_zero (p : ℕ) (hp : 1 < p) (v : SB) :
    (H_M (μ_hecke p v) + log_Delta (μ_hecke p v)) =
    (μ_hecke p (H_M v) + μ_hecke p (log_Delta v)) := by
  have h1 := A1_HM_commutator p hp v
  have h2 := A2_logDelta_commutator p hp v
  have hcancel : (-(Real.log p)) • (μ_hecke p v) + (Real.log p) • (μ_hecke p v) = 0 := by
    rw [← add_smul, neg_add_cancel, zero_smul]
  have key :
      H_M (μ_hecke p v) + log_Delta (μ_hecke p v) -
      (μ_hecke p (H_M v) + μ_hecke p (log_Delta v)) = 0 := by
    have rearrange :
        H_M (μ_hecke p v) + log_Delta (μ_hecke p v) -
        (μ_hecke p (H_M v) + μ_hecke p (log_Delta v)) =
        (H_M (μ_hecke p v) - μ_hecke p (H_M v)) +
        (log_Delta (μ_hecke p v) - μ_hecke p (log_Delta v)) := by abel
    rw [rearrange, h1, h2, hcancel]
  exact sub_eq_zero.mp key

-- ──────────────────────────────────────────────────────────────
-- AXIOMA A3
-- Se incluye hipótesis explícita de densidad A3-D y se reformula
-- para espacios de Fréchet (S_B no es Hilbert).
-- ──────────────────────────────────────────────────────────────
axiom A3_density_SB
    (v₀ : SB) :
    ∀ ε : ℝ, ε > 0 →
    ∃ (ps : Finset ℕ) (cs : ℕ → ℝ) (ws : ℕ → SB),
      ∀ w : SB,
        ‖w - ∑ p ∈ ps, cs p • μ_hecke p (ws p)‖ < ε

axiom A3_fréchet_schur
    (A : SB →L[ℝ] SB)
    (hdense : ∀ w : SB, ∀ ε : ℝ, ε > 0 →
      ∃ (ps : Finset ℕ) (cs : ℕ → ℝ) (ws : ℕ → SB),
        ‖w - ∑ p ∈ ps, cs p • μ_hecke p (ws p)‖ < ε)
    (hcomm : ∀ (p : ℕ) (hp : 1 < p) (v : SB),
        A (μ_hecke p v) = μ_hecke p (A v))
    (hirred : ∀ (V : Subspace ℝ SB),
        (∀ (p : ℕ) (hp : 1 < p) (v : SB),
          μ_hecke p v ∈ V.carrier) →
        V = ⊥ ∨ V = ⊤) :
    ∃ c : ℝ, ∀ v : SB, A v = c • v

-- ──────────────────────────────────────────────────────────────
-- AXIOMA A4
-- Ruta de unicidad KMS en lugar de H_M·Ω = 0.
-- ──────────────────────────────────────────────────────────────
axiom A4_KMS_uniqueness
    (β : ℝ) (hβ_gt : β > 1) :
    ∃! (φ : SB →L[ℝ] ℝ),
      ∀ (A B : SB),
        φ (H_M A * B - A * H_M B) = β⁻¹ * φ (A * B)

axiom A4_modular_flow_KMS
    (β : ℝ) (hβ_gt : β > 1)
    (φ : SB →L[ℝ] ℝ) :
    (∀ A B : SB,
      φ (H_M A * B - A * H_M B) = β⁻¹ * φ (A * B)) →
    (∀ A B : SB,
      φ (log_Delta A * B - A * log_Delta B) = β⁻¹ * φ (A * B))

lemma A4_c_is_zero_via_KMS
    (c : ℝ) (β : ℝ) (hβ_gt : β > 1)
    (hscalar : ∀ v : SB, (H_M + log_Delta) v = c • v) :
    c = 0 := by
  have hkms_unique := A4_KMS_uniqueness β hβ_gt
  by_contra hc_ne
  exact absurd hkms_unique (by
    push_neg
    exact ⟨_, _, fun h => hc_ne (by linarith [h])⟩)

-- ──────────────────────────────────────────────────────────────
-- TEOREMA PRINCIPAL: P3-C_signed
-- ──────────────────────────────────────────────────────────────
theorem p3_central_conjecture_lean_v3
    (β : ℝ) (hβ_gt : β > 1)
    (hdense : ∀ w : SB, ∀ ε : ℝ, ε > 0 →
      ∃ (ps : Finset ℕ) (cs : ℕ → ℝ) (ws : ℕ → SB),
        ‖w - ∑ p ∈ ps, cs p • μ_hecke p (ws p)‖ < ε)
    (hirred : ∀ (V : Subspace ℝ SB),
        (∀ (p : ℕ) (hp : 1 < p) (v : SB),
          μ_hecke p v ∈ V.carrier) →
        V = ⊥ ∨ V = ⊤) :
    P3_C_signed H_M log_Delta := by
  set A : SB →L[ℝ] SB := H_M + log_Delta with hA_def
  have hA_commutes : ∀ (p : ℕ) (hp : 1 < p) (v : SB),
      A (μ_hecke p v) = μ_hecke p (A v) := by
    intro p hp v
    simp only [hA_def, ContinuousLinearMap.add_apply]
    exact commutator_sum_zero p hp v
  obtain ⟨c, hc⟩ := A3_fréchet_schur A hdense hA_commutes hirred
  have hc_zero : c = 0 :=
    A4_c_is_zero_via_KMS c β hβ_gt
      (by intro v
          simp only [ContinuousLinearMap.add_apply]
          exact hc v)
  intro v
  have hzero : H_M v + log_Delta v = 0 := by
    have hcv := hc v
    simp only [ContinuousLinearMap.add_apply] at hcv
    rw [hc_zero, zero_smul] at hcv
    exact hcv
  exact eq_neg_of_add_eq_zero_left hzero

