-- BM-SG: ARCHIVO 2 — P2-C Aritmética de Divisores
-- Propósito: Formalizar los lemas L1, L2, L4 de la suite P2-C.
-- Dependencias: Mathlib.NumberTheory.Divisors, Mathlib.Data.Nat.Squarefree
-- Expectativa: L1 y L4 sin sorry; la identidad de varianza (variance_identity)
--              tiene un sorry técnico (Finset.sum) documentado.
-- ============================================================

import Mathlib.Data.Nat.Basic
import Mathlib.Data.Nat.GCD.Basic
import Mathlib.Data.Finset.Basic
import Mathlib.NumberTheory.Divisors
import Mathlib.Data.Nat.Squarefree

open Nat Finset

-- ─────────────────────────────────────────────────────────────
-- DEFINICIÓN: función de representación r_sq
-- r_sq(D, M, n) = #{(d,m): dm=n, d≤D, m≤M, squarefree(d)}
-- ─────────────────────────────────────────────────────────────

def r_sq (D M n : ℕ) : ℕ :=
  (n.divisors.filter (fun d =>
    d ≤ D ∧
    n / d ≤ M ∧
    Squarefree d)).card

@[simp]
lemma r_sq_zero (D M : ℕ) : r_sq D M 0 = 0 := by
  simp [r_sq, Nat.divisors]

-- ─────────────────────────────────────────────────────────────
-- LEMA L1-PASO: r_sq(D,M,n) ≤ τ(n) = n.divisors.card
-- ─────────────────────────────────────────────────────────────

theorem r_sq_le_tau (D M n : ℕ) :
    r_sq D M n ≤ n.divisors.card := by
  unfold r_sq
  exact Finset.card_filter_le _ _

-- ─────────────────────────────────────────────────────────────
-- LEMA L1-ENERGÍA: energía squarefree dominada por energía divisor
-- ─────────────────────────────────────────────────────────────

def E_sq (D M : ℕ) : ℕ :=
  ∑ n ∈ Finset.Icc 1 (D * M), (r_sq D M n) ^ 2

def E_tau (N : ℕ) : ℕ :=
  ∑ n ∈ Finset.Icc 1 N, (n.divisors.card) ^ 2

theorem E_sq_le_E_tau (D M : ℕ) :
    E_sq D M ≤ E_tau (D * M) := by
  unfold E_sq E_tau
  apply Finset.sum_le_sum
  intro n _
  apply Nat.pow_le_pow_left
  exact r_sq_le_tau D M n

-- ─────────────────────────────────────────────────────────────
-- LEMA L4: colapso discreto para enteros
-- ─────────────────────────────────────────────────────────────

lemma int_diff_lt_one_eq (a b : ℤ) (h : |a - b| < 1) : a = b := by
  omega

theorem l4_discrete_collapse (d1 d2 m1 m2 : ℤ)
    (hd1 : 0 < d1) (hd2 : 0 < d2)
    (hm1 : 0 < m1) (hm2 : 0 < m2)
    (h : |d1 * m1 - d2 * m2| < 1) :
    d1 * m1 = d2 * m2 := by
  have := int_diff_lt_one_eq (d1 * m1) (d2 * m2) h
  linarith [this]

-- ─────────────────────────────────────────────────────────────
-- DEFINICIÓN: Varianza de r_sq
-- ─────────────────────────────────────────────────────────────

noncomputable def r_bar_int (D M : ℕ) : ℚ :=
  (∑ n ∈ Finset.Icc 1 (D * M), (r_sq D M n : ℚ)) /
  (D * M : ℚ)

noncomputable def variance_r_sq_q (D M : ℕ) : ℚ :=
  ∑ n ∈ Finset.Icc 1 (D * M),
    ((r_sq D M n : ℚ) - r_bar_int D M) ^ 2

-- ─────────────────────────────────────────────────────────────
-- TEOREMA P2-R: identidad de varianza
-- SORRY: requiere lema de identidad de Finset.sum para la
-- expansión Σ(xᵢ - x̄)² = Σxᵢ² - n·x̄².
-- La identidad algebraica es correcta; la táctica ring_nf
-- no la cierra automáticamente sobre Finset.
-- ─────────────────────────────────────────────────────────────

theorem variance_identity (D M : ℕ) (hDM : 0 < D * M) :
    variance_r_sq_q D M =
    (∑ n ∈ Finset.Icc 1 (D * M), (r_sq D M n : ℚ) ^ 2) -
    (D * M : ℚ) * (r_bar_int D M) ^ 2 := by
  unfold variance_r_sq_q r_bar_int
  simp only [sub_sq]
  rw [Finset.sum_sub_distrib]
  simp only [Finset.sum_sub_distrib, Finset.sum_add_distrib]
  ring_nf
  sorry

-- ─────────────────────────────────────────────────────────────
-- ENUNCIADO FORMAL DE P2-C-CORE (conjetura, no demostración)
-- ─────────────────────────────────────────────────────────────

def P2_C_CORE (σ ε : ℝ) : Prop :=
  ∃ C : ℝ, C > 0 ∧
  ∀ D M : ℕ, (D : ℝ) > 0 → (M : ℝ) > 0 →
    let N : ℝ := (D : ℝ) * (M : ℝ)
    (variance_r_sq_q D M : ℝ) ≤ C * N ^ (1 + ε - σ)

-- ─────────────────────────────────────────────────────────────
-- VERIFICACIÓN
-- ─────────────────────────────────────────────────────────────

#check r_sq_le_tau
#check E_sq_le_E_tau
#check int_diff_lt_one_eq
#check l4_discrete_collapse
#check variance_identity    -- (tiene sorry documentado)
#check P2_C_CORE

